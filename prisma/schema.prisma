// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  user
  admin
}

enum PricingType {
  free
  premium
}

enum PurchaseType {
  rent
  buy
  subscription
}

enum PurchaseProvider {
  stripe
  paypal
  razorpay
}

enum PaymentGatewayProvider {
  stripe
  sslcommerz
  portwallet
  bkash
  nagad
  rocket
}

enum PurchaseMethod {
  card
  wallet
}

enum PaymentMethodType {
  visa
  debit_card
  credit_card
  bkash
  nagad
  rocket
}

enum PaymentCheckoutStatus {
  pending
  processing
  paid
  failed
}

enum PurchaseStatus {
  active
  expired
  revoked
  refunded
}

enum PurchasePlan {
  monthly
  yearly
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  passwordHash  String?
  role          UserRole  @default(user)
  provider      String?
  providerId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  reviews          Review[]
  reviewLikes      ReviewLike[]
  reviewComments   ReviewComment[]
  watchlistItems   WatchlistItem[]
  watchProgresses  WatchProgress[]
  watchHistories   WatchHistory[]
  purchases        Purchase[]
  paymentCheckouts PaymentCheckout[]
  resetTokens      PasswordResetToken[]
  sessions         Session[]
  accounts         Account[]

  @@index([role])
  @@index([provider, providerId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Media {
  id           String      @id @default(uuid())
  title        String
  synopsis     String
  genres       String[]
  releaseYear  Int
  director     String
  cast         String[]
  platforms    String[]
  pricing      PricingType @default(free)
  streamingUrl String      @unique
  poster       String
  duration     String
  popularity   Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  reviews         Review[]
  watchlistItems  WatchlistItem[]
  watchProgresses WatchProgress[]
  watchHistories  WatchHistory[]
  purchases       Purchase[]

  @@index([releaseYear])
  @@index([createdAt])
  @@index([popularity])
}

model Review {
  id               String           @id @default(uuid())
  mediaId          String
  userId           String
  rating           Int
  content          String
  tags             String[]
  spoiler          Boolean          @default(false)
  isPublished      Boolean          @default(false)
  moderationStatus ModerationStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  media    Media           @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes    ReviewLike[]
  comments ReviewComment[]

  @@index([mediaId, isPublished])
  @@index([userId])
  @@index([moderationStatus])
}

model ReviewLike {
  reviewId  String
  userId    String
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([reviewId, userId])
}

model ReviewComment {
  id              String   @id @default(uuid())
  reviewId        String
  userId          String
  content         String
  parentCommentId String?
  createdAt       DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reviewId, createdAt])
}

model WatchlistItem {
  userId  String
  mediaId String
  addedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([userId, mediaId])
  @@index([addedAt])
}

model WatchProgress {
  userId          String
  mediaId         String
  progressSeconds Int      @default(0)
  updatedAt       DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([userId, mediaId])
}

model WatchHistory {
  id              String   @id @default(uuid())
  userId          String
  mediaId         String
  watchedAt       DateTime @default(now())
  progressSeconds Int      @default(0)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([userId, watchedAt])
}

model Purchase {
  id                    String           @id @default(uuid())
  userId                String
  mediaId               String?
  type                  PurchaseType
  plan                  PurchasePlan?
  provider              PurchaseProvider
  method                PurchaseMethod
  amount                Int
  cardLast4             String?
  checkoutId            String?
  gatewayTransactionId  String?
  sendConfirmationEmail Boolean          @default(false)
  expiresAt             DateTime?
  status                PurchaseStatus   @default(active)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  media Media? @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PaymentCheckout {
  id                 String                 @id @default(uuid())
  checkoutId         String                 @unique
  transactionId      String                 @unique
  userId             String
  type               PurchaseType           @default(subscription)
  plan               PurchasePlan?
  amount             Int
  currency           String                 @default("USD")
  provider           PaymentGatewayProvider
  method             PurchaseMethod
  paymentMethodType  PaymentMethodType
  cardLast4          String?
  cardToken          String?
  walletProvider     String?
  walletNumberMasked String?
  emailReceipt       Boolean                @default(false)
  idempotencyKey     String?
  status             PaymentCheckoutStatus  @default(pending)
  paymentUrl         String?
  gatewayRef         String?
  failedReason       String?
  paidAt             DateTime?
  metadata           Json?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs PaymentAuditLog[]

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
  @@index([status])
}

model PaymentAuditLog {
  id            String   @id @default(uuid())
  checkoutId    String?
  transactionId String?
  source        String
  event         String
  requestBody   Json?
  responseBody  Json?
  responseCode  Int?
  createdAt     DateTime @default(now())

  checkout PaymentCheckout? @relation(fields: [checkoutId], references: [checkoutId], onDelete: SetNull)

  @@index([checkoutId, createdAt])
  @@index([transactionId, createdAt])
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  icon      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
